@model PagedList<Client>
@using Sabara.Web.ViewModel
@{
    ViewData["Title"] = "العملاء";
    ViewData["Subtitle"] = $"إجمالي العملاء: {ViewBag.TotalCount}";

    string search = ViewBag.Search as string ?? "";
    ClientStatus? statusFilter = ViewBag.StatusFilter as ClientStatus?;
    int total = (int)(ViewBag.TotalCount ?? 0);
    int leads = (int)(ViewBag.LeadCount ?? 0);
    int active = (int)(ViewBag.ActiveCount ?? 0);
    int inactive = (int)(ViewBag.InactiveCount ?? 0);
    int lost = (int)(ViewBag.LostCount ?? 0);

    ViewData["PaginationAction"] = "Index";
    ViewData["PaginationController"] = "Clients";
    ViewData["RouteValues"] = new Dictionary<string, string?>
    {
        ["search"] = search,
        ["status"] = statusFilter?.ToString(),
    };
}

@await Html.PartialAsync("_Toast")

<!-- Summary cards -->
<div class="grid grid-cols-2 md:grid-cols-5 gap-3 lg:gap-4 mb-5">
    <a href="/Clients/Index" class="bg-white rounded-2xl p-4 shadow-card hover:shadow-lg transition @(statusFilter == null ? "ring-2 ring-brand-gold" : "")">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-brand-surface text-brand-gold-2 grid place-items-center">
                <i class="bi bi-people-fill"></i>
            </div>
            <div>
                <div class="text-xl font-extrabold text-brand-ink">@total</div>
                <div class="text-[11px] text-brand-ink/60">الكل</div>
            </div>
        </div>
    </a>
    <a href="/Clients/Index?status=Lead" class="bg-white rounded-2xl p-4 shadow-card hover:shadow-lg transition @(statusFilter == ClientStatus.Lead ? "ring-2 ring-amber-400" : "")">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-amber-100 text-amber-700 grid place-items-center">
                <i class="bi bi-stars"></i>
            </div>
            <div>
                <div class="text-xl font-extrabold text-brand-ink">@leads</div>
                <div class="text-[11px] text-brand-ink/60">محتمل</div>
            </div>
        </div>
    </a>
    <a href="/Clients/Index?status=Active" class="bg-white rounded-2xl p-4 shadow-card hover:shadow-lg transition @(statusFilter == ClientStatus.Active ? "ring-2 ring-emerald-400" : "")">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-emerald-100 text-emerald-700 grid place-items-center">
                <i class="bi bi-check-circle-fill"></i>
            </div>
            <div>
                <div class="text-xl font-extrabold text-brand-ink">@active</div>
                <div class="text-[11px] text-brand-ink/60">نشط</div>
            </div>
        </div>
    </a>
    <a href="/Clients/Index?status=Inactive" class="bg-white rounded-2xl p-4 shadow-card hover:shadow-lg transition @(statusFilter == ClientStatus.Inactive ? "ring-2 ring-slate-400" : "")">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-slate-100 text-slate-600 grid place-items-center">
                <i class="bi bi-pause-circle-fill"></i>
            </div>
            <div>
                <div class="text-xl font-extrabold text-brand-ink">@inactive</div>
                <div class="text-[11px] text-brand-ink/60">متوقف</div>
            </div>
        </div>
    </a>
    <a href="/Clients/Index?status=Lost" class="bg-white rounded-2xl p-4 shadow-card hover:shadow-lg transition @(statusFilter == ClientStatus.Lost ? "ring-2 ring-red-400" : "")">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-red-100 text-red-700 grid place-items-center">
                <i class="bi bi-x-circle-fill"></i>
            </div>
            <div>
                <div class="text-xl font-extrabold text-brand-ink">@lost</div>
                <div class="text-[11px] text-brand-ink/60">مفقود</div>
            </div>
        </div>
    </a>
</div>

<div class="bg-white rounded-2xl shadow-card overflow-hidden">
    <div class="p-5 lg:p-6 border-b border-brand-surface">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-4">
            <div>
                <h2 class="text-xl font-extrabold text-brand-ink flex items-center gap-2">
                    <i class="bi bi-people-fill text-brand-gold"></i>
                    قاعدة العملاء
                </h2>
                <p class="text-xs text-brand-ink/60 mt-1">إدارة كاملة لعلاقات العملاء والمحتملين</p>
            </div>
            <a href="/Clients/Create" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl bg-brand-gold text-brand-ink font-bold hover:bg-yellow-400 transition shadow">
                <i class="bi bi-person-plus-fill"></i> عميل جديد
            </a>
        </div>

        <form method="get" class="grid grid-cols-1 md:grid-cols-12 gap-3">
            <input type="hidden" name="status" value="@statusFilter" />
            <div class="md:col-span-10">
                <div class="relative">
                    <i class="bi bi-search absolute top-1/2 -translate-y-1/2 right-4 text-brand-ink/40"></i>
                    <input type="text" name="search" value="@search"
                           placeholder="ابحث بالاسم، الشركة، الهاتف أو البريد..."
                           class="w-full pr-11 pl-4 py-3 rounded-xl bg-brand-bg border border-brand-surface focus:border-brand-gold focus:bg-white focus:ring-2 focus:ring-brand-gold/20 outline-none transition text-sm" />
                </div>
            </div>
            <div class="md:col-span-2 flex gap-2">
                <button type="submit" class="flex-1 py-3 rounded-xl bg-brand-ink text-white font-bold hover:bg-brand-ink/90 transition text-sm">تصفية</button>
                <a href="/Clients/Index" class="w-12 grid place-items-center rounded-xl bg-brand-surface text-brand-ink hover:bg-brand-surface/70 transition">
                    <i class="bi bi-arrow-clockwise"></i>
                </a>
            </div>
        </form>
    </div>

    @if (Model.Items.Count == 0)
    {
        <div class="text-center py-20">
            <div class="w-20 h-20 rounded-2xl bg-brand-surface mx-auto flex items-center justify-center mb-4">
                <i class="bi bi-people text-3xl text-brand-gold-2"></i>
            </div>
            <h3 class="text-lg font-extrabold text-brand-ink">لا يوجد عملاء بعد</h3>
            <p class="text-sm text-brand-ink/60 mt-1">ابدأ ببناء قاعدة عملائك</p>
            <a href="/Clients/Create" class="inline-flex items-center gap-2 mt-5 px-5 py-2.5 rounded-xl bg-brand-gold text-brand-ink font-bold hover:bg-yellow-400 transition">
                <i class="bi bi-person-plus-fill"></i> أضف عميلاً
            </a>
        </div>
    }
    else
    {
        <div class="p-4 lg:p-6 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            @foreach (var c in Model.Items)
            {
                var (bg, txt) = c.Status.Colors();
                <a href="/Clients/Details/@c.Id" class="block bg-brand-bg hover:bg-white border border-brand-surface hover:border-brand-gold rounded-2xl p-5 transition shadow-sm hover:shadow-card">
                    <div class="flex items-start gap-3 mb-3">
                        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-brand-gold to-brand-green text-white flex items-center justify-center font-bold text-lg">
                            @(string.IsNullOrEmpty(c.Name) ? "?" : c.Name.Substring(0,1))
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="font-bold text-brand-ink truncate">@c.Name</div>
                            @if (!string.IsNullOrEmpty(c.CompanyName))
                            {
                                <div class="text-xs text-brand-ink/60 truncate"><i class="bi bi-building"></i> @c.CompanyName</div>
                            }
                        </div>
                        <span class="text-[10px] font-bold px-2.5 py-1 rounded-full @bg @txt whitespace-nowrap">@c.Status.Label()</span>
                    </div>

                    <div class="space-y-1.5 text-xs text-brand-ink/70">
                        <div class="flex items-center gap-2 ltr-text" dir="ltr"><i class="bi bi-telephone text-brand-ink/40"></i> @c.PhoneNumber</div>
                        @if (!string.IsNullOrEmpty(c.Email))
                        {
                            <div class="flex items-center gap-2 truncate ltr-text" dir="ltr"><i class="bi bi-envelope text-brand-ink/40"></i> @c.Email</div>
                        }
                        @if (!string.IsNullOrEmpty(c.City))
                        {
                            <div class="flex items-center gap-2"><i class="bi bi-geo-alt text-brand-ink/40"></i> @c.City</div>
                        }
                    </div>

                    <div class="flex items-center justify-between mt-4 pt-3 border-t border-brand-surface text-[11px] text-brand-ink/50">
                        <span><i class="bi bi-calendar3"></i> @c.CreatedAt.ToString("yyyy/MM/dd")</span>
                        <span class="font-bold text-brand-gold-2">@c.Source.Label()</span>
                    </div>
                </a>
            }
        </div>

        <div class="border-t border-brand-surface">
            @await Html.PartialAsync("_Pagination", Model)
        </div>
    }
</div>
