@{
    Layout = "_LayoutMain";

}


<main class="main">

    <!-- Page Title -->
    <div class="page-title dark-background" data-aos="fade">
        <div class="container position-relative">
            <h1>تفاصيل الخدمة</h1>
            <p>نُصمم بروشورات وفلايرات وملصقات بجودة عالية تعكس رسالتك التسويقية للجمهور بوضوح.</p>
            <nav class="breadcrumbs">
                <ol>
                    <li><a href="index.html">الرئيسية</a></li>
                    <li class="current">تفاصيل الخدمة</li>
                </ol>
            </nav>
        </div>
    </div><!-- End Page Title -->
    <!-- Service Details Section -->
    <section id="service-details" class="service-details section">

        <div class="container" data-aos="fade-up" data-aos-delay="100">

            <div class="row gy-5">

                <div class="col-lg-8 order-lg-1 order-2">
                    <div class="service-main-content">
                        <div class="service-header" data-aos="fade-up">
                            <h1>تصميم إعلانات مطبوعة</h1>
                            <div class="service-meta">
                                <span><i class="bi bi-printer"></i> دقة وجودة عالية</span>
                                <span><i class="bi bi-layout-text-window"></i> تصميم احترافي</span>
                                <span><i class="bi bi-star-fill"></i> تقييم 5/5</span>
                            </div>
                            <p class="lead">
                                نُصمم بروشورات وفلايرات وملصقات بجودة عالية تعكس رسالتك التسويقية للجمهور بوضوح.
                            </p>
                        </div>

                        <div class="service-tabs" data-aos="fade-up" data-aos-delay="200">
                            <ul class="nav nav-tabs" id="serviceTab" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#service-details-tab-1" type="button" role="tab" aria-controls="overview" aria-selected="true">
                                        <i class="bi bi-info-circle"></i> نظرة عامة
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-2" type="button" role="tab" aria-controls="process" aria-selected="false">
                                        <i class="bi bi-diagram-3"></i> العملية
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-3" type="button" role="tab" aria-controls="benefits" aria-selected="false">
                                        <i class="bi bi-graph-up-arrow"></i> المميزات
                                    </button>
                                </li>
                            </ul>

                            <div class="tab-content">

                                <div class="tab-pane fade show active" id="service-details-tab-1" role="tabpanel" aria-labelledby="overview-tab">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="content-block">
                                                <h3>تصاميم مطبوعة تلفت الأنظار</h3>
                                                <p>نقدم لك تصاميم بروشورات، فلايرات، وملصقات تعكس هوية علامتك وتوصل رسالتك بوضوح.</p>
                                                <p>تصاميم قابلة للطباعة بجودة عالية ومناسبة لجميع أنواع المواد الدعائية.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <img src="~/assets/img/logo.png" alt="تصميم إعلانات مطبوعة" class="img-fluid rounded">
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-2" role="tabpanel" aria-labelledby="process-tab">
                                    <div class="process-timeline">
                                        <div class="timeline-item">
                                            <div class="timeline-marker">01</div>
                                            <div class="timeline-content">
                                                <h4>فهم المحتوى والهدف</h4>
                                                <p>نحدد الرسالة التسويقية ونوع المادة الإعلانية المطلوبة والجمهور المستهدف.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">02</div>
                                            <div class="timeline-content">
                                                <h4>تصميم مخصص</h4>
                                                <p>نبدأ بتصميم الشكل المبدئي وفق الهوية البصرية للعلامة وبأسلوب جذاب.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">03</div>
                                            <div class="timeline-content">
                                                <h4>مراجعة وتعديل</h4>
                                                <p>نشاركك التصميم ونقوم بالتعديلات اللازمة حتى الوصول إلى النتيجة النهائية.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">04</div>
                                            <div class="timeline-content">
                                                <h4>تسليم ملفات جاهزة للطباعة</h4>
                                                <p>نُسلم الملفات بصيغ عالية الجودة للطباعة أو للنشر الرقمي.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-3" role="tabpanel" aria-labelledby="benefits-tab">
                                    <div class="row g-4">
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-printer-fill"></i>
                                                </div>
                                                <h4>جودة طباعة عالية</h4>
                                                <p>تصاميم مهيأة بالكامل للطباعة بدون فقدان الدقة أو الألوان.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-bullseye"></i>
                                                </div>
                                                <h4>رسالة واضحة ومباشرة</h4>
                                                <p>التصميم يُبرز أهم النقاط بطريقة مرئية تسويقية فعالة.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-layout-text-sidebar-reverse"></i>
                                                </div>
                                                <h4>تنسيق احترافي للمحتوى</h4>
                                                <p>نُحسن ترتيب النصوص والصور لضمان أفضل تجربة للقراءة والنظر.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-palette"></i>
                                                </div>
                                                <h4>إبداع في التصميم</h4>
                                                <p>نمزج بين الجاذبية البصرية والأسلوب التسويقي لتحقيق أعلى تأثير.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div> <!-- /tab-content -->
                        </div> <!-- /service-tabs -->
                    </div> <!-- /service-main-content -->
                </div> <!-- /col-lg-8 -->

                <div class="col-lg-4 order-lg-2 order-1">
                    <div class="service-sidebar" data-aos="fade-left">
                        <div class="action-card" data-aos="zoom-in" data-aos-delay="100">
                            <h3>هل تحتاج إعلانًا مطبوعًا يلفت الانتباه؟</h3>
                            <p>نُصمم لك إعلانًا يُعبّر عن فكرتك ويُبرز علامتك بطريقة إبداعية واحترافية.</p>
                            <a href="#" class="btn-primary" data-bs-toggle="modal" data-bs-target="#orderModal"
                               data-packagename="خدمة/ تصميم إعلانات مطبوعة  ">اطلب الآن</a>                            <span class="guarantee"><i class="bi bi-shield-check"></i> تصميم مضمون الجودة</span>
                        </div>

                        <div class="contact-info" data-aos="fade-up" data-aos-delay="400">
                            <h4>هل لديك أسئلة؟</h4>
                            <div class="contact-method">
                                <i class="bi bi-telephone-fill"></i>
                                <div>
                                    <span>اتصل بنا الآن</span>
                                    <p>
                                        972591234567
                                    </p>
                                </div>
                            </div>
                            <div class="contact-method">
                                <i class="bi bi-envelope-fill"></i>
                                <div>
                                    <span>راسلنا عبر البريد</span>
                                    <p>SabaraTech@gmail.com</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div> <!-- /col-lg-4 -->

            </div> <!-- /row -->

        </div> <!-- /container -->

    </section><!-- /Service Details Section -->

</main>
