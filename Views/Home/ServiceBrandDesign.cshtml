@{
    Layout = "_LayoutMain";

}


<main class="main">

    <!-- Page Title -->
    <div class="page-title dark-background" data-aos="fade">
        <div class="container position-relative">
            <h1>تفاصيل الخدمة</h1>
            <p>نُقدم شعارات وألواناً ومواد تعريفية متناسقة تُعبر عن شخصية علامتك التجارية بكل احترافية.</p>
            <nav class="breadcrumbs">
                <ol>
                    <li><a href="index.html">الرئيسية</a></li>
                    <li class="current">تفاصيل الخدمة</li>
                </ol>
            </nav>
        </div>
    </div><!-- End Page Title -->
    <!-- Service Details Section -->
    <section id="service-details" class="service-details section">

        <div class="container" data-aos="fade-up" data-aos-delay="100">

            <div class="row gy-5">

                <div class="col-lg-8 order-lg-1 order-2">
                    <div class="service-main-content">
                        <div class="service-header" data-aos="fade-up">
                            <h1>تصميم الهوية التجارية</h1>
                            <div class="service-meta">
                                <span><i class="bi bi-award"></i> إبداع وتميز</span>
                                <span><i class="bi bi-palette-fill"></i> تصميم متكامل</span>
                                <span><i class="bi bi-star-fill"></i> تقييم 5/5</span>
                            </div>
                            <p class="lead">
                                نُقدم شعارات وألواناً ومواد تعريفية متناسقة تُعبر عن شخصية علامتك التجارية بكل احترافية.
                            </p>
                        </div>

                        <div class="service-tabs" data-aos="fade-up" data-aos-delay="200">
                            <ul class="nav nav-tabs" id="serviceTab" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#service-details-tab-1" type="button" role="tab" aria-controls="overview" aria-selected="true">
                                        <i class="bi bi-info-circle"></i> نظرة عامة
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-2" type="button" role="tab" aria-controls="process" aria-selected="false">
                                        <i class="bi bi-diagram-3"></i> العملية
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-3" type="button" role="tab" aria-controls="benefits" aria-selected="false">
                                        <i class="bi bi-graph-up-arrow"></i> المميزات
                                    </button>
                                </li>
                            </ul>

                            <div class="tab-content">

                                <div class="tab-pane fade show active" id="service-details-tab-1" role="tabpanel" aria-labelledby="overview-tab">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="content-block">
                                                <h3>هوية بصرية تنبض بشخصيتك</h3>
                                                <p>نُصمم هوية تعكس رؤيتك وقيمك وتمنح علامتك حضورًا قويًا ومتناسقًا في السوق.</p>
                                                <p>نُقدم حلولاً تشمل الشعار، الألوان، الخطوط، والمواد الطباعية الرقمية.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <img src="~/assets/img/logo.png" alt="تصميم الهوية التجارية" class="img-fluid rounded">
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-2" role="tabpanel" aria-labelledby="process-tab">
                                    <div class="process-timeline">
                                        <div class="timeline-item">
                                            <div class="timeline-marker">01</div>
                                            <div class="timeline-content">
                                                <h4>دراسة العلامة التجارية</h4>
                                                <p>نبدأ بتحليل السوق ونقاط القوة والرسالة التي تريد إيصالها لعملائك.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">02</div>
                                            <div class="timeline-content">
                                                <h4>تصميم الشعار والعناصر البصرية</h4>
                                                <p>نبتكر شعارًا احترافيًا يعكس هوية مشروعك ويُستخدم في مختلف التطبيقات.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">03</div>
                                            <div class="timeline-content">
                                                <h4>اختيار الألوان والخطوط</h4>
                                                <p>نُحدد نظام ألوان وهوية خطية تدعم الشعار وتُظهره بشكل جذاب ومتناسق.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">04</div>
                                            <div class="timeline-content">
                                                <h4>إعداد دليل الهوية</h4>
                                                <p>نُقدّم ملفًا توضيحيًا يشرح استخدامات الهوية بطريقة احترافية وسهلة التنفيذ.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-3" role="tabpanel" aria-labelledby="benefits-tab">
                                    <div class="row g-4">
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-person-badge"></i>
                                                </div>
                                                <h4>هوية فريدة</h4>
                                                <p>تجعل علامتك تبرز وسط المنافسين بأسلوب بصري احترافي.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-palette-fill"></i>
                                                </div>
                                                <h4>اتساق بصري كامل</h4>
                                                <p>تناغم في كل عناصر الهوية، من الشعار إلى الأدوات التسويقية.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-file-earmark-richtext"></i>
                                                </div>
                                                <h4>ملف هوية شامل</h4>
                                                <p>يحوي كل التفاصيل البصرية بطريقة منظمة لتسهيل استخدامها.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-megaphone"></i>
                                                </div>
                                                <h4>تعزيز ولاء العملاء</h4>
                                                <p>هوية قوية تُساعد العملاء على تذكرك والتفاعل معك بثقة.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div> <!-- /tab-content -->
                        </div> <!-- /service-tabs -->
                    </div> <!-- /service-main-content -->
                </div> <!-- /col-lg-8 -->

                <div class="col-lg-4 order-lg-2 order-1">
                    <div class="service-sidebar" data-aos="fade-left">
                        <div class="action-card" data-aos="zoom-in" data-aos-delay="100">
                            <h3>هل تبحث عن هوية تعكس تميزك؟</h3>
                            <p>دعنا نساعدك في بناء هوية تجارية تترك انطباعاً لا يُنسى لدى جمهورك.</p>
                            <a href="#" class="btn-primary" data-bs-toggle="modal" data-bs-target="#orderModal"
                               data-packagename="خدمة/ تصميم الهوية التجارية ">ابدأ بهويتك الآن</a>

                            <span class="guarantee"><i class="bi bi-shield-check"></i> إبداع مضمون</span>
                        </div>

                        <div class="contact-info" data-aos="fade-up" data-aos-delay="400">
                            <h4>هل لديك أسئلة؟</h4>
                            <div class="contact-method">
                                <i class="bi bi-telephone-fill"></i>
                                <div>
                                    <span>اتصل بنا الآن</span>
                                    <p>972591234567</p>
                                </div>
                            </div>
                            <div class="contact-method">
                                <i class="bi bi-envelope-fill"></i>
                                <div>
                                    <span>راسلنا عبر البريد</span>
                                    <p>SabaraTech@gmail.com</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div> <!-- /col-lg-4 -->

            </div> <!-- /row -->

        </div> <!-- /container -->

    </section><!-- /Service Details Section -->

</main>