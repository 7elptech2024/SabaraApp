@{
    Layout = "_LayoutMain";

}


<main class="main">

    <!-- Page Title -->
    <div class="page-title dark-background" data-aos="fade">
        <div class="container position-relative">
            <h1>تفاصيل الخدمة</h1>
            <p>نُصمم واجهات جذابة ومتجاوبة تناسب جميع الأجهزة وتُظهر موقعك بشكل عصري ومميز للمستخدمين.</p>
            <nav class="breadcrumbs">
                <ol>
                    <li><a href="index.html">الرئيسية</a></li>
                    <li class="current">تفاصيل الخدمة</li>
                </ol>
            </nav>
        </div>
    </div><!-- End Page Title -->
    <!-- Service Details Section -->
    <section id="service-details" class="service-details section">

        <div class="container" data-aos="fade-up" data-aos-delay="100">

            <div class="row gy-5">

                <div class="col-lg-8 order-lg-1 order-2">
                    <div class="service-main-content">
                        <div class="service-header" data-aos="fade-up">
                            <h1>تصميم واجهات المواقع</h1>
                            <div class="service-meta">
                                <span><i class="bi bi-award"></i> تصميم احترافي</span>
                                <span><i class="bi bi-clock"></i> متجاوب مع جميع الأجهزة</span>
                                <span><i class="bi bi-star-fill"></i> تقييم 5/5</span>
                            </div>
                            <p class="lead">
                                نُصمم واجهات جذابة ومتجاوبة تناسب جميع الأجهزة وتُظهر موقعك بشكل عصري ومميز للمستخدمين.
                            </p>
                        </div>

                        <div class="service-tabs" data-aos="fade-up" data-aos-delay="200">
                            <ul class="nav nav-tabs" id="serviceTab" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#service-details-tab-1" type="button" role="tab" aria-controls="overview" aria-selected="true">
                                        <i class="bi bi-info-circle"></i> نظرة عامة
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-2" type="button" role="tab" aria-controls="process" aria-selected="false">
                                        <i class="bi bi-diagram-3"></i> العملية
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-3" type="button" role="tab" aria-controls="benefits" aria-selected="false">
                                        <i class="bi bi-graph-up-arrow"></i> المميزات
                                    </button>
                                </li>
                            </ul>

                            <div class="tab-content">

                                <div class="tab-pane fade show active" id="service-details-tab-1" role="tabpanel" aria-labelledby="overview-tab">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="content-block">
                                                <h3>تصميم عصري ومتجاوب</h3>
                                                <p>نقوم بتصميم واجهات مستخدم عصرية وجذابة تعكس هوية مشروعك وتجذب الزوار.</p>
                                                <p>نركز على تجربة المستخدم وسهولة الاستخدام، مع توافق تام مع الهواتف والأجهزة اللوحية.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <img src="~/assets/img/logo.png" alt="تصميم واجهات المواقع" class="img-fluid rounded">
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-2" role="tabpanel" aria-labelledby="process-tab">
                                    <div class="process-timeline">
                                        <div class="timeline-item">
                                            <div class="timeline-marker">01</div>
                                            <div class="timeline-content">
                                                <h4>فهم احتياجات المشروع</h4>
                                                <p>نجتمع مع العميل لفهم الأهداف، الهوية البصرية، ونوعية الجمهور المستهدف.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">02</div>
                                            <div class="timeline-content">
                                                <h4>رسم التصاميم الأولية</h4>
                                                <p>إنشاء تصاميم مبدئية (Wireframes) واستعراض البنية العامة للواجهة.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">03</div>
                                            <div class="timeline-content">
                                                <h4>تصميم واجهات نهائية</h4>
                                                <p>تصميم صفحات متكاملة بألوان وهوية بصرية متناسقة وتوافق تام مع تجربة المستخدم.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">04</div>
                                            <div class="timeline-content">
                                                <h4>تسليم الملفات والدعم</h4>
                                                <p>تسليم التصميمات بجميع الصيغ المطلوبة مع دعم فني للتعديلات النهائية.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-3" role="tabpanel" aria-labelledby="benefits-tab">
                                    <div class="row g-4">
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-aspect-ratio"></i>
                                                </div>
                                                <h4>توافق كامل مع الأجهزة</h4>
                                                <p>تصاميم متجاوبة تعمل بكفاءة على جميع الشاشات من الجوال حتى شاشات سطح المكتب.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-palette"></i>
                                                </div>
                                                <h4>هوية بصرية مميزة</h4>
                                                <p>نلتزم بأحدث معايير التصميم لإظهار موقعك بشكل يعكس احترافيتك.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-person-check"></i>
                                                </div>
                                                <h4>سهولة الاستخدام</h4>
                                                <p>نُصمم واجهات بسيطة وسلسة تمنح الزائر تجربة مريحة وسريعة.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-eye"></i>
                                                </div>
                                                <h4>جاذبية بصرية عالية</h4>
                                                <p>تصاميم عصرية تجذب انتباه الزوار وتزيد من فرص التفاعل والنجاح.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div> <!-- /tab-content -->
                        </div> <!-- /service-tabs -->
                    </div> <!-- /service-main-content -->
                </div> <!-- /col-lg-8 -->

                <div class="col-lg-4 order-lg-2 order-1">
                    <div class="service-sidebar" data-aos="fade-left">
                        <div class="action-card" data-aos="zoom-in" data-aos-delay="100">
                            <h3>هل ترغب في تصميم واجهة فريدة لموقعك؟</h3>
                            <p>نحن هنا لنقدم لك واجهات احترافية تعزز تجربة المستخدم وتُبرز علامتك التجارية.</p>
                            <a href="#" class="btn-primary" data-bs-toggle="modal" data-bs-target="#orderModal"
                               data-packagename="خدمة/تصميم واجهات المواقع  "> احصل على تصميمك الآن</a>
                            <span class="guarantee"><i class="bi bi-shield-check"></i> جودة مضمونة</span>
                        </div>

                        <div class="contact-info" data-aos="fade-up" data-aos-delay="400">
                            <h4>هل لديك أسئلة؟</h4>
                            <div class="contact-method">
                                <i class="bi bi-telephone-fill"></i>
                                <div>
                                    <span>اتصل بنا الآن</span>
                                    <p>972591234567</p>
                                </div>
                            </div>
                            <div class="contact-method">
                                <i class="bi bi-envelope-fill"></i>
                                <div>
                                    <span>راسلنا عبر البريد</span>
                                    <p>SabaraTech@gmail.com</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div> <!-- /col-lg-4 -->

            </div> <!-- /row -->

        </div> <!-- /container -->

    </section><!-- /Service Details Section -->

</main>