@{
    Layout = "_LayoutMain";

}
<main class="main">

    <!-- Page Title -->
    <div class="page-title dark-background" data-aos="fade">
        <div class="container position-relative">
            <h1>تفاصيل الخدمة</h1>
            <p>نُنتج فيديوهات تعريفية أو إعلانية بجودة عالية تساعد على توصيل رسالتك بسرعة وجاذبية.</p>
            <nav class="breadcrumbs">
                <ol>
                    <li><a href="index.html">الرئيسية</a></li>
                    <li class="current">تفاصيل الخدمة</li>
                </ol>
            </nav>
        </div>
    </div><!-- End Page Title -->
    <!-- Service Details Section -->
    <section id="service-details" class="service-details section">

        <div class="container" data-aos="fade-up" data-aos-delay="100">

            <div class="row gy-5">

                <div class="col-lg-8 order-lg-1 order-2">
                    <div class="service-main-content">
                        <div class="service-header" data-aos="fade-up">
                            <h1>تصميم الفيديوهات الترويجية</h1>
                            <div class="service-meta">
                                <span><i class="bi bi-camera-video-fill"></i> جودة عالية</span>
                                <span><i class="bi bi-stopwatch"></i> إيصال سريع للرسالة</span>
                                <span><i class="bi bi-star-fill"></i> تقييم 5/5</span>
                            </div>
                            <p class="lead">
                                نُنتج فيديوهات تعريفية أو إعلانية بجودة عالية تساعد على توصيل رسالتك بسرعة وجاذبية.
                            </p>
                        </div>

                        <div class="service-tabs" data-aos="fade-up" data-aos-delay="200">
                            <ul class="nav nav-tabs" id="serviceTab" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#service-details-tab-1" type="button" role="tab" aria-controls="overview" aria-selected="true">
                                        <i class="bi bi-info-circle"></i> نظرة عامة
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-2" type="button" role="tab" aria-controls="process" aria-selected="false">
                                        <i class="bi bi-diagram-3"></i> العملية
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-3" type="button" role="tab" aria-controls="benefits" aria-selected="false">
                                        <i class="bi bi-graph-up-arrow"></i> المميزات
                                    </button>
                                </li>
                            </ul>

                            <div class="tab-content">

                                <div class="tab-pane fade show active" id="service-details-tab-1" role="tabpanel" aria-labelledby="overview-tab">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="content-block">
                                                <h3>فيديوهات تعرّف وتجذب</h3>
                                                <p>نُنتج فيديوهات قصيرة أو متوسطة الطول تشرح فكرتك أو تروج لخدمتك بأسلوب احترافي.</p>
                                                <p>تتناسب الفيديوهات مع المنصات الرقمية وتُصمم خصيصًا لتتناسب مع جمهورك المستهدف.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <img src="~/assets/img/logo.png" alt="تصميم الفيديوهات الترويجية" class="img-fluid rounded">
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-2" role="tabpanel" aria-labelledby="process-tab">
                                    <div class="process-timeline">
                                        <div class="timeline-item">
                                            <div class="timeline-marker">01</div>
                                            <div class="timeline-content">
                                                <h4>تحديد الهدف والمحتوى</h4>
                                                <p>نجتمع معك لفهم الفكرة، الرسالة، والجمهور المستهدف للفيديو.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">02</div>
                                            <div class="timeline-content">
                                                <h4>كتابة السكربت وتحديد الأسلوب</h4>
                                                <p>نكتب سيناريو مختصر مع تحديد نوع الفيديو (موشن، واقعي، رسوم...).</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">03</div>
                                            <div class="timeline-content">
                                                <h4>إنتاج الفيديو</h4>
                                                <p>يتم تنفيذ الفيديو بتنسيق جذاب مع مؤثرات صوتية وبصرية قوية.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">04</div>
                                            <div class="timeline-content">
                                                <h4>المراجعة والتسليم</h4>
                                                <p>نقوم بالتعديلات النهائية ثم نسلم لك الفيديو بصيغ عالية الجودة.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-3" role="tabpanel" aria-labelledby="benefits-tab">
                                    <div class="row g-4">
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-film"></i>
                                                </div>
                                                <h4>إخراج احترافي</h4>
                                                <p>نعتمد على أدوات متقدمة وفريق متخصص لإنتاج فيديوهات بجودة سينمائية.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-lightning-charge"></i>
                                                </div>
                                                <h4>إيصال سريع للرسالة</h4>
                                                <p>نعرض فكرتك خلال ثوانٍ قليلة بأقصى تأثير ممكن على المشاهد.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-share"></i>
                                                </div>
                                                <h4>قابلية عالية للمشاركة</h4>
                                                <p>الفيديوهات تزيد من فرصة الانتشار والتفاعل عبر وسائل التواصل.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-camera-reels"></i>
                                                </div>
                                                <h4>أنواع متعددة</h4>
                                                <p>موشن جرافيك، فيديو واقعي، رسوم توضيحية حسب ما يناسب علامتك.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div> <!-- /tab-content -->
                        </div> <!-- /service-tabs -->
                    </div> <!-- /service-main-content -->
                </div> <!-- /col-lg-8 -->

                <div class="col-lg-4 order-lg-2 order-1">
                    <div class="service-sidebar" data-aos="fade-left">
                        <div class="action-card" data-aos="zoom-in" data-aos-delay="100">
                            <h3>هل ترغب في فيديو يترك أثرًا؟</h3>
                            <p>نُنتج لك فيديو ترويجي يعكس رؤيتك ويُعرض بأسلوب عصري وجذاب.</p>
                            <a href="#" class="btn-primary" data-bs-toggle="modal" data-bs-target="#orderModal"
                               data-packagename="خدمة/تصميم الفيديوهات الترويجية ">اطلب الآن</a>                            <span class="guarantee"><i class="bi bi-shield-check"></i> جودة مضمونة</span>
                        </div>

                        <div class="contact-info" data-aos="fade-up" data-aos-delay="400">
                            <h4>هل لديك أسئلة؟</h4>
                            <div class="contact-method">
                                <i class="bi bi-telephone-fill"></i>
                                <div>
                                    <span>اتصل بنا الآن</span>
                                    <p>972591234567</p>
                                </div>
                            </div>
                            <div class="contact-method">
                                <i class="bi bi-envelope-fill"></i>
                                <div>
                                    <span>راسلنا عبر البريد</span>
                                    <p>SabaraTech@gmail.com</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div> <!-- /col-lg-4 -->

            </div> <!-- /row -->

        </div> <!-- /container -->

    </section><!-- /Service Details Section -->

</main>