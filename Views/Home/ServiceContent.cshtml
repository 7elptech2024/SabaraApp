@{
    Layout = "_LayoutMain";

}


<main class="main">

    <!-- Page Title -->
    <div class="page-title dark-background" data-aos="fade">
        <div class="container position-relative">
            <h1>تفاصيل الخدمة</h1>
            <p>نكتب محتوى تسويقياً موجهاً ومؤثراً لمواقعك وإعلاناتك ليصل رسالتك للجمهور بأفضل طريقة.</p>
            <nav class="breadcrumbs">
                <ol>
                    <li><a href="index.html">الرئيسية</a></li>
                    <li class="current">تفاصيل الخدمة</li>
                </ol>
            </nav>
        </div>
    </div><!-- End Page Title -->
    <!-- Service Details Section -->
    <section id="service-details" class="service-details section">

        <div class="container" data-aos="fade-up" data-aos-delay="100">

            <div class="row gy-5">

                <div class="col-lg-8 order-lg-1 order-2">
                    <div class="service-main-content">
                        <div class="service-header" data-aos="fade-up">
                            <h1>كتابة المحتوى التسويقي</h1>
                            <div class="service-meta">
                                <span><i class="bi bi-pencil-fill"></i> كتابة احترافية</span>
                                <span><i class="bi bi-bullseye"></i> رسائل موجّهة</span>
                                <span><i class="bi bi-star-fill"></i> تقييم 5/5</span>
                            </div>
                            <p class="lead">
                                نكتب محتوى تسويقياً موجهاً ومؤثراً لمواقعك وإعلاناتك ليصل رسالتك للجمهور بأفضل طريقة.
                            </p>
                        </div>

                        <div class="service-tabs" data-aos="fade-up" data-aos-delay="200">
                            <ul class="nav nav-tabs" id="serviceTab" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#service-details-tab-1" type="button" role="tab" aria-controls="overview" aria-selected="true">
                                        <i class="bi bi-info-circle"></i> نظرة عامة
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-2" type="button" role="tab" aria-controls="process" aria-selected="false">
                                        <i class="bi bi-diagram-3"></i> العملية
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-3" type="button" role="tab" aria-controls="benefits" aria-selected="false">
                                        <i class="bi bi-graph-up-arrow"></i> المميزات
                                    </button>
                                </li>
                            </ul>

                            <div class="tab-content">

                                <div class="tab-pane fade show active" id="service-details-tab-1" role="tabpanel" aria-labelledby="overview-tab">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="content-block">
                                                <h3>محتوى يُحدث فرقاً</h3>
                                                <p>نُقدم محتوى تسويقياً موجهاً يعبر عن هوية علامتك ويقنع جمهورك باتخاذ القرار.</p>
                                                <p>نكتب لمواقع الويب، الإعلانات، الحملات الترويجية، وصف المنتجات والمزيد.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <img src="~/assets/img/logo.png" alt="كتابة المحتوى التسويقي" class="img-fluid rounded">
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-2" role="tabpanel" aria-labelledby="process-tab">
                                    <div class="process-timeline">
                                        <div class="timeline-item">
                                            <div class="timeline-marker">01</div>
                                            <div class="timeline-content">
                                                <h4>دراسة العلامة والجمهور</h4>
                                                <p>نفهم طبيعة نشاطك التجاري والجمهور المستهدف ونبرة الصوت المطلوبة.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">02</div>
                                            <div class="timeline-content">
                                                <h4>كتابة المسودات</h4>
                                                <p>نبدأ بصياغة محتوى أولي يركز على القيمة التسويقية ويبرز نقاط القوة.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">03</div>
                                            <div class="timeline-content">
                                                <h4>التحرير والتحسين</h4>
                                                <p>نُراجع المحتوى لغويًا وتسويقيًا ونعزز الرسالة بأسلوب إبداعي جذاب.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">04</div>
                                            <div class="timeline-content">
                                                <h4>التسليم والمراجعة</h4>
                                                <p>نُسلم المحتوى النهائي بصيغ قابلة للنشر، مع إمكانية التعديل حسب الملاحظات.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-3" role="tabpanel" aria-labelledby="benefits-tab">
                                    <div class="row g-4">
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-journal-richtext"></i>
                                                </div>
                                                <h4>كتابة مقنعة</h4>
                                                <p>نُحول المعلومات إلى رسائل قوية تؤثر في القرار الشرائي.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-people"></i>
                                                </div>
                                                <h4>لغة موجهة للجمهور</h4>
                                                <p>نكتب بأسلوب يتحدث مع جمهورك بلغته ويحقق التفاعل المطلوب.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-globe"></i>
                                                </div>
                                                <h4>ملائم لجميع المنصات</h4>
                                                <p>محتوى مناسب للمواقع، المتاجر الإلكترونية، السوشيال ميديا، الإعلانات والمزيد.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-graph-up"></i>
                                                </div>
                                                <h4>يعزز المبيعات</h4>
                                                <p>يساعد في رفع نسب التحويل وتحقيق أهدافك التسويقية بفعالية.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div> <!-- /tab-content -->
                        </div> <!-- /service-tabs -->
                    </div> <!-- /service-main-content -->
                </div> <!-- /col-lg-8 -->

                <div class="col-lg-4 order-lg-2 order-1">
                    <div class="service-sidebar" data-aos="fade-left">
                        <div class="action-card" data-aos="zoom-in" data-aos-delay="100">
                            <h3>هل تحتاج لمحتوى يبيع ويقنع؟</h3>
                            <p>اطلب خدمة كتابة المحتوى التسويقي ودعنا نكتب لك بأسلوب احترافي يحقق النتائج.</p>
                            <a href="#" class="btn-primary" data-bs-toggle="modal" data-bs-target="#orderModal"
                               data-packagename="خدمة/كتابة المحتوى التسويقي  ">اطلب الآن</a>                            <span class="guarantee"><i class="bi bi-shield-check"></i> محتوى بجودة مضمونة</span>
                        </div>

                        <div class="contact-info" data-aos="fade-up" data-aos-delay="400">
                            <h4>هل لديك أسئلة؟</h4>
                            <div class="contact-method">
                                <i class="bi bi-telephone-fill"></i>
                                <div>
                                    <span>اتصل بنا الآن</span>
                                    <p>972591234567</p>
                                </div>
                            </div>
                            <div class="contact-method">
                                <i class="bi bi-envelope-fill"></i>
                                <div>
                                    <span>راسلنا عبر البريد</span>
                                    <p>SabaraTech@gmail.com</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div> <!-- /col-lg-4 -->

            </div> <!-- /row -->

        </div> <!-- /container -->

    </section><!-- /Service Details Section -->

</main>