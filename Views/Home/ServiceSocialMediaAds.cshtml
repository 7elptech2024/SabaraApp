@{
    Layout = "_LayoutMain";

}

<main class="main">

    <!-- Page Title -->
    <div class="page-title dark-background" data-aos="fade">
        <div class="container position-relative">
            <h1>تفاصيل الخدمة</h1>
            <p>تصاميم احترافية ومناسبة لمختلف المنصات الاجتماعية، تُساعدك على جذب العملاء بشكل فعّال.</p>
            <nav class="breadcrumbs">
                <ol>
                    <li><a href="index.html">الرئيسية</a></li>
                    <li class="current">تفاصيل الخدمة</li>
                </ol>
            </nav>
        </div>
    </div><!-- End Page Title -->
    <!-- Service Details Section -->
    <section id="service-details" class="service-details section">

        <div class="container" data-aos="fade-up" data-aos-delay="100">

            <div class="row gy-5">

                <div class="col-lg-8 order-lg-1 order-2">
                    <div class="service-main-content">
                        <div class="service-header" data-aos="fade-up">
                            <h1>إعلانات السوشيال ميديا</h1>
                            <div class="service-meta">
                                <span><i class="bi bi-megaphone-fill"></i> تفاعل قوي</span>
                                <span><i class="bi bi-phone-fill"></i> متجاوبة مع المنصات</span>
                                <span><i class="bi bi-star-fill"></i> تقييم 5/5</span>
                            </div>
                            <p class="lead">
                                تصاميم احترافية ومناسبة لمختلف المنصات الاجتماعية، تُساعدك على جذب العملاء بشكل فعّال.
                            </p>
                        </div>

                        <div class="service-tabs" data-aos="fade-up" data-aos-delay="200">
                            <ul class="nav nav-tabs" id="serviceTab" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#service-details-tab-1" type="button" role="tab" aria-controls="overview" aria-selected="true">
                                        <i class="bi bi-info-circle"></i> نظرة عامة
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-2" type="button" role="tab" aria-controls="process" aria-selected="false">
                                        <i class="bi bi-diagram-3"></i> العملية
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-3" type="button" role="tab" aria-controls="benefits" aria-selected="false">
                                        <i class="bi bi-graph-up-arrow"></i> المميزات
                                    </button>
                                </li>
                            </ul>

                            <div class="tab-content">

                                <div class="tab-pane fade show active" id="service-details-tab-1" role="tabpanel" aria-labelledby="overview-tab">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="content-block">
                                                <h3>تصاميم جذابة لمنصاتك الاجتماعية</h3>
                                                <p>نُصمم إعلانات سوشيال ميديا بأحجام وأبعاد مناسبة لكل منصة لضمان ظهور احترافي.</p>
                                                <p>تصاميم تركز على جذب الانتباه وتحفيز التفاعل مع علامتك التجارية.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <img src="~/assets/img/logo.png" alt="إعلانات السوشيال ميديا" class="img-fluid rounded">
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-2" role="tabpanel" aria-labelledby="process-tab">
                                    <div class="process-timeline">
                                        <div class="timeline-item">
                                            <div class="timeline-marker">01</div>
                                            <div class="timeline-content">
                                                <h4>تحديد أهداف الإعلان</h4>
                                                <p>نبدأ بفهم هدف الإعلان سواء كان توعوي، ترويجي، أو لزيادة التفاعل والمبيعات.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">02</div>
                                            <div class="timeline-content">
                                                <h4>اختيار الأسلوب البصري المناسب</h4>
                                                <p>نُحدد الطابع العام للتصميم بناءً على هوية المشروع والجمهور المستهدف.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">03</div>
                                            <div class="timeline-content">
                                                <h4>تصميم الإعلان</h4>
                                                <p>نُنفذ التصميم بأبعاد دقيقة وجودة عالية تتوافق مع كل منصة (إنستغرام، سناب، فيسبوك...).</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">04</div>
                                            <div class="timeline-content">
                                                <h4>التسليم والتعديلات</h4>
                                                <p>نُسلم الملفات بصيغ PNG أو JPEG مع إمكانية التعديل بناءً على ملاحظاتك.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-3" role="tabpanel" aria-labelledby="benefits-tab">
                                    <div class="row g-4">
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-images"></i>
                                                </div>
                                                <h4>تصاميم جذابة</h4>
                                                <p>تُلفت الأنظار وتُبرز رسالتك التسويقية بوضوح وبأسلوب احترافي.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-phone-landscape"></i>
                                                </div>
                                                <h4>أحجام مناسبة لكل منصة</h4>
                                                <p>نُجهز التصاميم بأبعاد مثالية لإنستغرام، سناب، تويتر، فيسبوك وغيرها.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-emoji-smile"></i>
                                                </div>
                                                <h4>تحفيز التفاعل</h4>
                                                <p>تصاميم تزيد من احتمالية مشاركة وتفاعل المستخدمين مع منشوراتك.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-share"></i>
                                                </div>
                                                <h4>انتشار أوسع</h4>
                                                <p>إعلاناتك المصممة باحترافية تصل لأكبر عدد من الجمهور المستهدف.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div> <!-- /tab-content -->
                        </div> <!-- /service-tabs -->
                    </div> <!-- /service-main-content -->
                </div> <!-- /col-lg-8 -->

                <div class="col-lg-4 order-lg-2 order-1">
                    <div class="service-sidebar" data-aos="fade-left">
                        <div class="action-card" data-aos="zoom-in" data-aos-delay="100">
                            <h3>هل ترغب في إعلان يجذب الانتباه؟</h3>
                            <p>اطلب تصميم إعلان سوشيال ميديا احترافي يساعدك على الوصول لجمهورك بسرعة وفعالية.</p>
                            <a href="#" class="btn-primary" data-bs-toggle="modal" data-bs-target="#orderModal"
                               data-packagename="خدمة/إعلانات السوشيال ميديا  ">اطلب الآن</a>           
                               <span class="guarantee"><i class="bi bi-shield-check"></i> تصميم مضمون الجاذبية</span>
                        </div>

                        <div class="contact-info" data-aos="fade-up" data-aos-delay="400">
                            <h4>هل لديك أسئلة؟</h4>
                            <div class="contact-method">
                                <i class="bi bi-telephone-fill"></i>
                                <div>
                                    <span>اتصل بنا الآن</span>
                                    <p>972591234567</p>
                                </div>
                            </div>
                            <div class="contact-method">
                                <i class="bi bi-envelope-fill"></i>
                                <div>
                                    <span>راسلنا عبر البريد</span>
                                    <p>SabaraTech@gmail.com</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div> <!-- /col-lg-4 -->

            </div> <!-- /row -->

        </div> <!-- /container -->

    </section><!-- /Service Details Section -->

</main>
