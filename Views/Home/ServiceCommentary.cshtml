@{
    Layout = "_LayoutMain";

}

<main class="main">

    <!-- Page Title -->
    <div class="page-title dark-background" data-aos="fade">
        <div class="container position-relative">
            <h1>تفاصيل الخدمة</h1>
            <p>تسجيلات وتعليقات صوتية احترافية باللغة العربية أو الإنجليزية تُناسب مشاريعك المختلفة.</p>
            <nav class="breadcrumbs">
                <ol>
                    <li><a href="index.html">الرئيسية</a></li>
                    <li class="current">تفاصيل الخدمة</li>
                </ol>
            </nav>
        </div>
    </div><!-- End Page Title -->
    <!-- Service Details Section -->
    <section id="service-details" class="service-details section">

        <div class="container" data-aos="fade-up" data-aos-delay="100">

            <div class="row gy-5">

                <div class="col-lg-8 order-lg-1 order-2">
                    <div class="service-main-content">
                        <div class="service-header" data-aos="fade-up">
                            <h1>التعليق والهندسة الصوتية</h1>
                            <div class="service-meta">
                                <span><i class="bi bi-mic-fill"></i> صوت احترافي</span>
                                <span><i class="bi bi-sliders"></i> معالجة متقنة</span>
                                <span><i class="bi bi-star-fill"></i> تقييم 5/5</span>
                            </div>
                            <p class="lead">
                                تسجيلات وتعليقات صوتية احترافية باللغة العربية أو الإنجليزية تُناسب مشاريعك المختلفة.
                            </p>
                        </div>

                        <div class="service-tabs" data-aos="fade-up" data-aos-delay="200">
                            <ul class="nav nav-tabs" id="serviceTab" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#service-details-tab-1" type="button" role="tab" aria-controls="overview" aria-selected="true">
                                        <i class="bi bi-info-circle"></i> نظرة عامة
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-2" type="button" role="tab" aria-controls="process" aria-selected="false">
                                        <i class="bi bi-diagram-3"></i> العملية
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-3" type="button" role="tab" aria-controls="benefits" aria-selected="false">
                                        <i class="bi bi-graph-up-arrow"></i> المميزات
                                    </button>
                                </li>
                            </ul>

                            <div class="tab-content">

                                <div class="tab-pane fade show active" id="service-details-tab-1" role="tabpanel" aria-labelledby="overview-tab">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="content-block">
                                                <h3>أداء صوتي احترافي</h3>
                                                <p>نُسجّل لك تعليقات صوتية بجودة عالية لمقاطع الفيديو، الإعلانات، الكتب المسموعة، وغيرها.</p>
                                                <p>متاح باللغة العربية أو الإنجليزية، بأداء مناسب لنوع المشروع المستهدف.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <img src="~/assets/img/logo.png" alt="التعليق والهندسة الصوتية" class="img-fluid rounded">
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-2" role="tabpanel" aria-labelledby="process-tab">
                                    <div class="process-timeline">
                                        <div class="timeline-item">
                                            <div class="timeline-marker">01</div>
                                            <div class="timeline-content">
                                                <h4>فهم المتطلبات الصوتية</h4>
                                                <p>نتعرف على نوع المشروع، اللغة المطلوبة، والنبرة المستهدفة (رسمية، حماسية، هادئة...).</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">02</div>
                                            <div class="timeline-content">
                                                <h4>التسجيل الصوتي</h4>
                                                <p>نُنفذ التسجيل في استوديو احترافي باستخدام معدات عالية الجودة لضمان وضوح الصوت.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">03</div>
                                            <div class="timeline-content">
                                                <h4>الهندسة والمعالجة</h4>
                                                <p>نقوم بتنظيف الصوت، تعديل المستويات، وإضافة المؤثرات الصوتية حسب الحاجة.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">04</div>
                                            <div class="timeline-content">
                                                <h4>المراجعة والتسليم</h4>
                                                <p>نشاركك النسخة الأولية ونقوم بأي تعديلات مطلوبة قبل التسليم النهائي بصيغ مختلفة.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-3" role="tabpanel" aria-labelledby="benefits-tab">
                                    <div class="row g-4">
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-mic"></i>
                                                </div>
                                                <h4>نقاء صوتي عالي</h4>
                                                <p>تسجيلات بدون ضوضاء وخالية من العيوب التقنية.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-translate"></i>
                                                </div>
                                                <h4>لغتان مدعومتان</h4>
                                                <p>تعليقات صوتية باللغة العربية أو الإنجليزية باحترافية عالية.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-sliders2-vertical"></i>
                                                </div>
                                                <h4>تحكم كامل بالنبرة</h4>
                                                <p>نُقدّم أداءً صوتيًا يتناسب مع نوع جمهورك والمحتوى المطلوب.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-folder-check"></i>
                                                </div>
                                                <h4>جاهزة للنشر</h4>
                                                <p>نسلّم الملفات بصيغ MP3 و WAV حسب الاستخدام المطلوب.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div> <!-- /tab-content -->
                        </div> <!-- /service-tabs -->
                    </div> <!-- /service-main-content -->
                </div> <!-- /col-lg-8 -->

                <div class="col-lg-4 order-lg-2 order-1">
                    <div class="service-sidebar" data-aos="fade-left">
                        <div class="action-card" data-aos="zoom-in" data-aos-delay="100">
                            <h3>هل تحتاج لصوت يُعبّر عن مشروعك؟</h3>
                            <p>اطلب تعليقًا صوتيًا احترافيًا أو معالجة لمقاطعك بجودة استوديو.</p>
                            <a href="#" class="btn-primary" data-bs-toggle="modal" data-bs-target="#orderModal"
                               data-packagename="خدمة/التعليق والهندسة الصوتية ">اطلب الآن</a>
                            <span class="guarantee"><i class="bi bi-shield-check"></i> تسليم دقيق وجودة عالية</span>
                        </div>
                        <div class="contact-info" data-aos="fade-up" data-aos-delay="400">
                            <h4>هل لديك أسئلة؟</h4>
                            <div class="contact-method">
                                <i class="bi bi-telephone-fill"></i>
                                <div>
                                    <span>اتصل بنا الآن</span>
                                    <p>
                                        972591234567
                                    </p>
                                </div>
                            </div>
                            <div class="contact-method">
                                <i class="bi bi-envelope-fill"></i>
                                <div>
                                    <span>راسلنا عبر البريد</span>
                                    <p>SabaraTech@gmail.com</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div> <!-- /col-lg-4 -->

            </div> <!-- /row -->

        </div> <!-- /container -->

    </section><!-- /Service Details Section -->

</main>