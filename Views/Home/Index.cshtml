@model List<Project>

@{
    Layout = "_LayoutMain";
}

<main class="main">

    <!-- قسم البطل -->
    <section id="hero" class="hero section">
        <div class="container">
            <div class="row">
                <div class="col-lg-7 content-col" data-aos="fade-up">
                    <div class="content">
                        <div class="agency-name">
                            <h5>وكالتنا الإبداعية</h5>
                        </div>

                        <div class="main-heading">
                            <h1>تصميم <br>إبداعي</h1>
                        </div>

                        <div class="divider"></div>

                        <div class="description">
                            <p>نصمم واجهات رقمية تعكس هوية شركتك بوضوح واحترافية. نعمل على تحويل الأفكار التسويقية إلى تجربة بصرية قوية تساعدك على التميز في السوق الرقمي. فريقنا يجمع بين الإبداع والدقة لتقديم موقع يعكس خدماتك بأفضل صورة.</p>
                        </div>

                        <div class="cta-button">
                            <a href="#services" class="btn">
                                <span>استكشف المشاريع</span>
                                <i class="bi bi-arrow-left"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5" data-aos="zoom-out">
                    <div class="visual-content">
                        <div class="fluid-shape">
                            <img src="~/assets/img/logo.png" alt="شكل سائل تجريدي" class="fluid-img">
                        </div>

                        <div class="stats-card d-flex align-items-center justify-content-between">
                            <div>
                                <div class="stats-number">
                                    <h2>5K</h2>
                                </div>
                                <div class="stats-label">
                                    <p>مشاريع منفذة</p>
                                </div>
                            </div>
                            <div class="stats-arrow ">
                                <a href="#portfolio"><i class="bi bi-arrow-up-left"></i></a>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </section><!-- /قسم البطل -->
    <!-- قسم من نحن -->
    <section id="about" class="about section">

        <!-- عنوان القسم -->
        <div class="container section-title" data-aos="fade-up">
            <h2>من نحن</h2>
            <div><span>تعرف على</span> <span class="description-title">المزيد عنا</span></div>
        </div><!-- نهاية عنوان القسم -->

        <div class="container">

            <div class="row gx-5 align-items-center">
                <div class="col-lg-6" data-aos="fade-right" data-aos-delay="200">
                    <div class="about-image position-relative">
                        <img src="~/assets/img/logo.png" class="img-fluid rounded-4 shadow-sm" alt="صورة عنا" loading="lazy">
                        <div class="experience-badge">
                            <span class="years">20+</span>
                            <span class="text">سنوات من الخبرة</span>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6 mt-4 mt-lg-0" data-aos="fade-left" data-aos-delay="300">
                    <div class="about-content">
                        <h2>من نحن</h2>
                        <p class="lead">
                            صبارة تك هي شركة فلسطينية متخصصة في تقديم حلول التسويق الرقمي وتصميم الهويات البصرية. نعمل على بناء واجهات رقمية تعكس احترافية العلامة التجارية، ونسعى لتقديم تجربة مستخدم سلسة تساهم في جذب العملاء وتحقيق الأهداف.
                        </p>
                        <p>
                            فريقنا يتميز بالخبرة والابتكار، ويستخدم أدوات حديثة لتقديم خدمات تشمل تصميم المواقع، تصميم الشعارات، كتابة المحتوى، وإدارة الحملات الإعلانية الرقمية. هدفنا هو رفع كفاءة ظهورك الرقمي وتعزيز تواصلك مع جمهورك المستهدف.
                        </p>

                        <div class="row g-4 mt-3">
                            <div class="col-md-6" data-aos="zoom-in" data-aos-delay="400">
                                <div class="feature-item">
                                    <i class="bi bi-check-circle-fill"></i>
                                    <h5>رؤيتنا</h5>
                                    <p>أن نكون الشريك الأول في تصميم وتطوير الحلول الرقمية للشركات الناشئة والمتوسطة في الوطن العربي.</p>
                                </div>
                            </div>
                            <div class="col-md-6" data-aos="zoom-in" data-aos-delay="450">
                                <div class="feature-item">
                                    <i class="bi bi-lightbulb-fill"></i>
                                    <h5>خبراتنا</h5>
                                    <p>نمتلك فريقًا متخصصًا في التصميم والتطوير والتسويق الرقمي بخبرة تمتد لأكثر من 5 سنوات.</p>
                                </div>
                            </div>
                        </div>

                        <a href="#" class="btn btn-primary mt-4">استكشف خدماتنا</a>
                    </div>
                </div>
            </div>

            <div class="testimonial-section mt-5 pt-5" data-aos="fade-up" data-aos-delay="100">
                <div class="row">
                    <div class="col-lg-4" data-aos="fade-right" data-aos-delay="200">
                        <div class="testimonial-intro">
                            <h3>عملاؤنا يتحدثون بإعجاب</h3>
                            <p>استمع مباشرة من أولئك الذين جربوا تأثير شراكتنا وحققوا أهدافهم الاستراتيجية.</p>
                            <div class="swiper-nav-buttons mt-4">
                                <button class="slider-prev"><i class="bi bi-arrow-right"></i></button>
                                <button class="slider-next"><i class="bi bi-arrow-left"></i></button>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-8" data-aos="fade-left" data-aos-delay="300">
                        <div class="testimonial-slider swiper init-swiper">
                            <script type="application/json" class="swiper-config">
                                {
                                  "loop": true,
                                  "speed": 800,
                                  "autoplay": {
                                    "delay": 5000
                                  },
                                  "slidesPerView": 1,
                                  "spaceBetween": 30,
                                  "navigation": {
                                    "nextEl": ".slider-next",
                                    "prevEl": ".slider-prev"
                                  },
                                  "breakpoints": {
                                    "768": {
                                      "slidesPerView": 2
                                    }
                                  }
                                }
                            </script>
                            <div class="swiper-wrapper">


                                <div class="swiper-slide">
                                    <div class="testimonial-item">
                                        <div class="rating mb-3">
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-half"></i>
                                        </div>
                                        <p>"كان التعاون مع فريقهم بمثابة كشف. قادتنا استراتيجياتهم المبتكرة نحو تحقيق أهدافنا بدقة وسرعة."</p>
                                        <div class="client-info d-flex align-items-center mt-4">
                                            <img src="~/assets/img/person/Person1.png" class="client-img" alt="عميل" loading="lazy">
                                            <div>
                                                <h6 class="mb-0">عبد الله العربي</h6>
                                                <span>مهندس حاسوب</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="swiper-slide">
                                    <div class="testimonial-item">
                                        <div class="rating mb-3">
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                        </div>
                                        <p>"عمق المعرفة والتفاني الذي يقدمونه في كل مشروع استثنائي. أصبحوا حليفًا أساسيًا في دفع توسعنا."</p>
                                        <div class="client-info d-flex align-items-center mt-4">
                                            <img src="~/assets/img/person/Person.png" class="client-img" alt="عميل" loading="lazy">
                                            <div>
                                                <h6 class="mb-0">مها عمر</h6>
                                                <span>كاتب</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="swiper-slide">
                                    <div class="testimonial-item">
                                        <div class="rating mb-3">
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                        </div>
                                        <p>
                                            "فريق محترف وفهمهم لاحتياجاتنا كان دقيقًا جدًا. التصميم الذي حصلنا عليه فاق توقعاتنا من حيث الجودة والدقة والسرعة في التسليم."
                                        </p>
                                        <div class="client-info d-flex align-items-center mt-4">
                                            <img src="~/assets/img/person/Person.png" class="client-img" alt="عميلة" loading="lazy">
                                            <div>
                                                <h6 class="mb-0">سارة العتيبي</h6>
                                                <span>مديرة تسويق رقمي</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>


                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </section><!-- /قسم من نحن -->
    <!-- قسم الخدمات -->
    <section id="services" class="services section">

        <!-- عنوان القسم -->
        <div class="container section-title" data-aos="fade-up">
            <h2>خدماتنا</h2>
            <div><span>اكتشف</span> <span class="description-title">خدماتنا</span></div>
        </div><!-- نهاية عنوان القسم -->

