@{
    Layout = "_LayoutMain";

}
<main class="main">

    <!-- Page Title -->
    <div class="page-title dark-background" data-aos="fade">
        <div class="container position-relative">
            <h1>تفاصيل الخدمة</h1>
            <p>نحن نقدم خدمة احترافية لإدارة المواقع الإلكترونية تشمل التحديث والصيانة والتحسين المستمر لضمان أداء مثالي وتجربة مستخدم متميزة.</p>
            <nav class="breadcrumbs">
                <ol>
                    <li><a href="index.html">الرئيسية</a></li>
                    <li class="current">تفاصيل الخدمة</li>
                </ol>
            </nav>
        </div>
    </div><!-- End Page Title -->
    <!-- Service Details Section -->
    <section id="service-details" class="service-details section">

        <div class="container" data-aos="fade-up" data-aos-delay="100">

            <div class="row gy-5">

                <div class="col-lg-8 order-lg-1 order-2">
                    <div class="service-main-content">
                        <div class="service-header" data-aos="fade-up">
                            <h1>إدارة المواقع الإلكترونية</h1>
                            <div class="service-meta">
                                <span><i class="bi bi-award"></i> خدمة مخصصة</span>
                                <span><i class="bi bi-clock"></i> متوفرة على مدار الساعة</span>
                                <span><i class="bi bi-star-fill"></i> تقييم 5/5</span>
                            </div>
                            <p class="lead">
                                نقوم بتحديث وصيانة المواقع لضمان استمرارية العمل وتحسين الأداء بشكل احترافي ومتكامل دائمًا.
                            </p>
                        </div>

                        <div class="service-tabs" data-aos="fade-up" data-aos-delay="200">
                            <ul class="nav nav-tabs" id="serviceTab" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#service-details-tab-1" type="button" role="tab" aria-controls="overview" aria-selected="true">
                                        <i class="bi bi-info-circle"></i> نظرة عامة
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-2" type="button" role="tab" aria-controls="process" aria-selected="false">
                                        <i class="bi bi-diagram-3"></i> العملية
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#service-details-tab-3" type="button" role="tab" aria-controls="benefits" aria-selected="false">
                                        <i class="bi bi-graph-up-arrow"></i> المميزات
                                    </button>
                                </li>
                            </ul>

                            <div class="tab-content">

                                <div class="tab-pane fade show active" id="service-details-tab-1" role="tabpanel" aria-labelledby="overview-tab">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="content-block">
                                                <h3>إدارة احترافية ومستدامة</h3>
                                                <p>نقوم بإدارة وتحديث موقعك بشكل دوري لضمان الأداء الأمثل وتجنب أي مشاكل تقنية.</p>
                                                <p>نهدف إلى تحسين تجربة المستخدم، سرعة التصفح، وتأمين الموقع من المخاطر المحتملة.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <img src="~/assets/img/logo.png" alt="إدارة المواقع الإلكترونية" class="img-fluid rounded">
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-2" role="tabpanel" aria-labelledby="process-tab">
                                    <div class="process-timeline">
                                        <div class="timeline-item">
                                            <div class="timeline-marker">01</div>
                                            <div class="timeline-content">
                                                <h4>تقييم الموقع الحالي</h4>
                                                <p>مراجعة شاملة لبنية الموقع، الأداء، والتحديثات المطلوبة لتحديد النقاط الحرجة.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">02</div>
                                            <div class="timeline-content">
                                                <h4>خطة الإدارة والصيانة</h4>
                                                <p>تحديد جدول زمني للتحديثات والمهام الشهرية والسنوية اللازمة للموقع.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">03</div>
                                            <div class="timeline-content">
                                                <h4>تنفيذ التحسينات</h4>
                                                <p>تطبيق التحديثات، إصلاح الأعطال، وتحسين الأداء العام للموقع.</p>
                                            </div>
                                        </div>

                                        <div class="timeline-item">
                                            <div class="timeline-marker">04</div>
                                            <div class="timeline-content">
                                                <h4>المتابعة والدعم</h4>
                                                <p>مراقبة مستمرة للموقع وتقديم تقارير دورية وصيانة فورية عند الحاجة.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="service-details-tab-3" role="tabpanel" aria-labelledby="benefits-tab">
                                    <div class="row g-4">
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-rocket-takeoff"></i>
                                                </div>
                                                <h4>أداء محسّن</h4>
                                                <p>تحسين سرعة الموقع واستجابته للحصول على تجربة مستخدم سلسة.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-shield-lock"></i>
                                                </div>
                                                <h4>أمان محدث دائمًا</h4>
                                                <p>نقوم بتحديث أنظمة الأمان وحمايتك من التهديدات والاختراقات.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-tools"></i>
                                                </div>
                                                <h4>صيانة استباقية</h4>
                                                <p>نقوم بالكشف المبكر عن المشكلات وإصلاحها قبل أن تؤثر على الزوار.</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="benefit-card">
                                                <div class="benefit-icon">
                                                    <i class="bi bi-bar-chart"></i>
                                                </div>
                                                <h4>تحليلات وتقارير</h4>
                                                <p>نوفر تقارير دورية تساعدك في فهم أداء موقعك واتخاذ قرارات فعّالة.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div> <!-- /tab-content -->
                        </div> <!-- /service-tabs -->
                    </div> <!-- /service-main-content -->
                </div> <!-- /col-lg-8 -->

                <div class="col-lg-4 order-lg-2 order-1">
                    <div class="service-sidebar" data-aos="fade-left">
                        <div class="action-card" data-aos="zoom-in" data-aos-delay="100">
                            <h3>هل ترغب في تحسين أداء موقعك؟</h3>
                            <p>دعنا نساعدك في صيانة موقعك وتطويره ليعمل بكفاءة واحترافية على مدار الساعة.</p>
                            <a href="#" class="btn-primary" data-bs-toggle="modal" data-bs-target="#orderModal"
                               data-packagename="خدمة/إدارة المواقع الإلكترونية  ">ابدأ الآن</a>
                            <span class="guarantee"><i class="bi bi-shield-check"></i> ضمان جودة الخدمة</span>
                        </div>

                        <div class="contact-info" data-aos="fade-up" data-aos-delay="400">
                            <h4>هل لديك أسئلة؟</h4>
                            <div class="contact-method">
                                <i class="bi bi-telephone-fill"></i>
                                <div>
                                    <span>اتصل بنا الآن</span>
                                    <p>972591234567</p>
                                </div>
                            </div>
                            <div class="contact-method">
                                <i class="bi bi-envelope-fill"></i>
                                <div>
                                    <span>راسلنا عبر البريد</span>
                                    <p>SabaraTech@gmail.com</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div> <!-- /col-lg-4 -->

            </div> <!-- /row -->

        </div> <!-- /container -->

    </section><!-- /Service Details Section -->

</main>